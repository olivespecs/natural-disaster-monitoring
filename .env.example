# Redis connection (auto-set by Docker Compose)
REDIS_URL=redis://redis:6379

# NASA EONET API (no key required — it's public)
EONET_API_URL=https://eonet.gsfc.nasa.gov/api/v3

# Polling configuration
POLL_INTERVAL_SECONDS=60
MAX_EVENTS_PER_POLL=50
EVENT_DAYS_WINDOW=7

# === Gemini AI (Optional) ===
# Leave blank to use the heuristic inference engine (works without a key).
# Add your Gemini API key to enable LLM-powered analysis.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
